# Server
PORT=8080

# Database (Railway: reference ${{Postgres.DATABASE_URL}})
DATABASE_URL=postgres://aac:aac_dev_password@localhost:5432/aac?sslmode=disable

# Auth
JWT_SECRET=change-me-in-production
TOKEN_TTL=720h

# Login Google: daftar OAuth client ID yang diterima sebagai audience,
# dipisah koma (web, iOS, Android). Kosongkan untuk menonaktifkan.
GOOGLE_CLIENT_IDS=

# Upload gambar (Railway: mount Volume lalu set ke /data/uploads)
UPLOAD_DIR=./uploads

# CORS untuk Flutter web, dipisah koma. * = semua origin.
ALLOWED_ORIGINS=*
